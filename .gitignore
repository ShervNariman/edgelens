# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# marketing capture binaries / scratch (keep README + checklist docs)
marketing/video/raw/*
!marketing/video/raw/.gitkeep.md
marketing/video/edited/*
!marketing/video/edited/.gitkeep.md
marketing/screenshots/raw/*
!marketing/screenshots/raw/.gitkeep.md
*.mp4
*.mov
*.webm
playwright-report/
test-results/
