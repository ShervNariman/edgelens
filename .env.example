# Release Room — local development defaults
# Copy to `.env.local` for Next.js. Zero-credential local mode works with these values.

# Runtime mode: "local" uses the file-backed adapter (no cloud DB credentials).
# Production should set DATABASE_ADAPTER=postgres and provide DATABASE_URL.
DATABASE_ADAPTER=local
DATABASE_URL=
DATA_DIR=.data

# Single private owner gate. Change before any shared deployment.
OWNER_EMAIL=owner@release-room.local
OWNER_PASSWORD=release-room-dev
# At least 32 characters. Generate with: openssl rand -base64 48
SESSION_SECRET=dev-only-change-me-to-a-long-random-secret-value

# Optional: public app URL used in absolute links
APP_URL=http://localhost:3000

# Editor/agent evidence bridge (HMAC shared secret for signed CLI deliveries).
# Generate with: openssl rand -hex 32
RELEASE_ROOM_EVIDENCE_SECRET=dev-only-evidence-secret-change-me
