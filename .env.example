# Analytics is inert when the project token is missing or explicitly disabled.
NEXT_PUBLIC_POSTHOG_ENABLED=false
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Release Room integrations (SHE-60 + SHE-69)
# Leave provider tokens empty to use fixture/demo adapters.
# Set tokens to activate live GitHub / Linear / Vercel without code changes.
RELEASE_ROOM_FORCE_FIXTURES=false
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
# Provider webhook secrets (SHE-69 authenticated ingress)
GITHUB_WEBHOOK_SECRET=
# GitHub App — required for check-run publishing writes (not for read/webhook ingest)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_WEBHOOK_SECRET=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_WEBHOOK_SECRET=
# Generic signed webhook ingestion (manual evidence)
RELEASE_ROOM_WEBHOOK_SECRET=
# Optional limits (defaults: 1 MiB body, 300s replay window)
RELEASE_ROOM_WEBHOOK_MAX_BODY_BYTES=1048576
RELEASE_ROOM_WEBHOOK_MAX_AGE_SECONDS=300
