# Optional Sherv OS explanation layer (server-only; never prefix the key with NEXT_PUBLIC_).
SHERV_OS_URL=http://127.0.0.1:3000
SHERV_OS_PROJECT_ID=edgelens
SHERV_OS_PROJECT_KEY=
